# DEEPSEEK_TEMPERATURE=0.3

# # ---------- Dashboard API ----------
# API_HOST=0.0.0.0
# API_PORT=8000


## ---------- General ----------
APP_NAME=meeting-ai
ENVIRONMENT=local
LOG_LEVEL=INFO
LOG_JSON=false

# ---------- Concurrency ----------
MAX_CONCURRENT_SESSIONS=5

# ---------- Storage ----------
# file | redis | oracle
STORAGE_BACKEND=file
STORAGE_ROOT=meetings

# Redis (future)
REDIS_URL=redis://localhost:6379/0
REDIS_NAMESPACE=meeting_ai

# Oracle 26ai (future)
ORACLE_DSN=
ORACLE_USER=
ORACLE_PASSWORD=

# ---------- Google / Playwright ----------
GOOGLE_EMAIL=multilinemlil@gmail.com
GOOGLE_PASSWORD=#Multiline99#
GOOGLE_STORAGE_STATE=auth/storage_state.json
HEADLESS=true
BROWSER_CHANNEL=chrome
# persistent (recommended) | cdp (most reliable) | launch (often blocked)
BROWSER_CONNECT_MODE=persistent
CHROME_USER_DATA_DIR=auth/chrome_profile
CDP_ENDPOINT=http://localhost:9222
JOIN_TIMEOUT_SECONDS=60
MAX_MEETING_MINUTES=180

# ---------- Audio recorder ----------
# Audio is captured with PyAudio from the system's default INPUT device.
# Leave AUDIO_INPUT_DEVICE_INDEX=-1 to use the default mic. To capture what
# other people say, install VB-CABLE, route Meet audio to it, then set this
# index to "CABLE Output" (find it via: python -m recorder.list_devices).
AUDIO_INPUT_DEVICE_INDEX=-1
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
# (ffmpeg-style fields below are kept for non-Windows/advanced setups)
AUDIO_INPUT_FORMAT=pulse
AUDIO_INPUT_DEVICE=default

# ---------- Whisper ----------
# faster-whisper | openai-whisper
WHISPER_ENGINE=faster-whisper
WHISPER_MODEL=small
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=en

# ---------- DeepSeek LLM ----------
DEEPSEEK_API_KEY=8e0c0a38e0cf4bdcbcf2609deef16a42
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=120
DEEPSEEK_MAX_TOKENS=2048
DEEPSEEK_TEMPERATURE=0.3

# ---------- Dashboard API ----------
API_HOST=0.0.0.0
API_PORT=8000