# APP_NAME=meeting-ai
# ENVIRONMENT=local
# LOG_LEVEL=INFO
# LOG_JSON=false

# # ---------- Concurrency ----------
# MAX_CONCURRENT_SESSIONS=5

# # ---------- Storage ----------
# # file | redis | oracle
# STORAGE_BACKEND=file
# STORAGE_ROOT=meetings

# # Redis (future)
# REDIS_URL=redis://localhost:6379/0
# REDIS_NAMESPACE=meeting_ai

# # Oracle 26ai (future)
# ORACLE_DSN=
# ORACLE_USER=
# ORACLE_PASSWORD=

# # ---------- Google / Playwright ----------
# GOOGLE_EMAIL=multilinemlil@gmail.com
# GOOGLE_PASSWORD=#Multiline99#
# GOOGLE_STORAGE_STATE=auth/storage_state.json
# HEADLESS=true
# BROWSER_CHANNEL=chrome
# JOIN_TIMEOUT_SECONDS=60
# MAX_MEETING_MINUTES=180

# # ---------- Audio recorder ----------
# # Linux/PulseAudio: AUDIO_INPUT_FORMAT=pulse AUDIO_INPUT_DEVICE=meeting_sink.monitor
# # macOS:            AUDIO_INPUT_FORMAT=avfoundation AUDIO_INPUT_DEVICE=":0"
# # Windows:          AUDIO_INPUT_FORMAT=dshow AUDIO_INPUT_DEVICE=audio="Stereo Mix"
# AUDIO_INPUT_FORMAT=pulse
# AUDIO_INPUT_DEVICE=default
# AUDIO_SAMPLE_RATE=16000
# AUDIO_CHANNELS=1

# # ---------- Whisper ----------
# # faster-whisper | openai-whisper
# WHISPER_ENGINE=faster-whisper
# WHISPER_MODEL=base
# WHISPER_DEVICE=auto
# WHISPER_COMPUTE_TYPE=int8
# WHISPER_LANGUAGE=

# # ---------- DeepSeek LLM ----------
# DEEPSEEK_API_KEY=sk-8e0c0a38e0cf4bdcbcf2609deef16a42
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_TIMEOUT_SECONDS=120
